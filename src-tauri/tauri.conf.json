{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Romaji Memo",
  "version": "0.1.0",
  "identifier": "com.ohya.romaji-memo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Romaji Memo",
        "width": 420,
        "height": 500,
        "minWidth": 320,
        "minHeight": 360,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: data: blob: 'unsafe-inline'"
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "clipboard-manager": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
